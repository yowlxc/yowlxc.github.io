u043b\u0430 \u0432 \u042e\u0433\u043e\u0440\u0441\u043a\u0438\u0439 \u0444\u0438\u0437\u0438\u043a\u043e-\u043c\u0430\u0442\u0435\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u043b\u0438\u0446\u0435\u0439 \u0438\u043d\u0442\u0435\u0440\u043d\u0430\u0442 (2023-2025), \u0433\u0434\u0435 \u043d\u0430\u0447\u0430\u043b\u0430 \u0441\u0432\u043e\u0439 \u043f\u0443\u0442\u044c \u0432 \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u043d\u0430\u0443\u043a\u0430\u0445. \u0421 2025 \u0433\u043e\u0434\u0430 \u044f \u043e\u0431\u0443\u0447\u0430\u044e\u0441\u044c \u0432 \u041d\u0418\u0423 \u0418\u0422\u041c\u041e \u043d\u0430 \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438 \"\u041d\u0435\u0439\u0440\u043e\u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0438 \u0438 \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435\" \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u044f 09.03.04 \"\u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u043d\u0430\u044f \u0438\u043d\u0436\u0435\u043d\u0435\u0440\u0438\u044f\" \u043d\u0430 \u0444\u0430\u043a\u0443\u043b\u044c\u0442\u0435\u0442\u0435 \u041f\u0418\u0438\u041a\u0422.</p>"},{"location":"about/#_4","title":"\u041e\u0441\u0432\u0430\u0438\u0432\u0430\u0435\u043c\u044b\u0435 \u043a\u0443\u0440\u0441\u044b","text":"<ul> <li>\"\u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 \u043d\u0430 Python\"</li> <li>\"\u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 \u043d\u0430 C++\" </li> <li>\"Deep Learning\"</li> </ul>"},{"location":"contacts/","title":"\u041c\u043e\u0438 \u043a\u043e\u043d\u0442\u0430\u043a\u0442\u044b","text":"<ul> <li>E-mail: yowlxc@gmail.com</li> <li>\u0412\u041a\u043e\u043d\u0442\u0430\u043a\u0442\u0435: vk.com/yowlxc</li> <li>Telegram: t.me/yowlxc</li> <li>GitHub: github.com/yowlxc</li> </ul>"},{"location":"projects/","title":"\u041c\u043e\u0438 \u043f\u0440\u043e\u0435\u043a\u0442\u044b","text":"<ul> <li>\u0421\u0435\u0440\u0432\u0435\u0440\u043d\u043e\u0435 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u0434\u043b\u044f \u043f\u043e\u043b\u0443\u0447\u0435\u043d\u0438\u044f \u0430\u043a\u0442\u0443\u0430\u043b\u044c\u043d\u044b\u0445 \u043a\u0443\u0440\u0441\u043e\u0432 \u0432\u0430\u043b\u044e\u0442 \u0441 \u0441\u0430\u0439\u0442\u0430 \u0426\u0411 \u0420\u0424 (Python)</li> <li>\u0412\u0435\u0431-\u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435, \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u044e\u0449\u0435\u0435 \u0434\u043e\u0431\u0430\u0432\u043b\u044f\u0442\u044c \u0432 \u043b\u0438\u0447\u043d\u044b\u0445 \u043a\u0430\u0442\u0430\u043b\u043e\u0433 \u043a\u043d\u0438\u0433\u0438, \u043e\u0446\u0435\u043d\u0438\u0432\u0430\u0442\u044c \u0438\u0445 \u0438 \u043f\u0438\u0441\u0430\u0442\u044c \u0440\u0435\u0446\u0435\u043d\u0437\u0438\u0438 (Python)</li> <li>\u041d\u0435\u0439\u0440\u043e\u043d\u043d\u0430\u044f \u0441\u0435\u0442\u044c, \u0441\u043f\u043e\u0441\u043e\u0431\u043d\u0430\u044f \u043a\u043b\u0430\u0441\u0442\u0435\u0440\u0438\u0437\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0434\u0430\u0442\u0430\u0441\u0435\u0442 \u0442\u043e\u0447\u0435\u043a (C++)</li> </ul>"},{"location":"labs/lab1/","title":"\u041b\u0430\u0431\u043e\u0440\u0430\u0442\u043e\u0440\u043d\u0430\u044f \u0440\u0430\u0431\u043e\u0442\u0430 \u21161","text":""},{"location":"labs/lab1/#_1","title":"\u0426\u0435\u043b\u0438","text":"<ul> <li>\u041e\u0441\u0432\u043e\u0438\u0442\u044c \u043f\u0440\u043e\u0446\u0435\u0441\u0441 \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044f \u0441\u0442\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0441\u0430\u0439\u0442\u0430 \u0441 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u0435\u043c \u0433\u0435\u043d\u0435\u0440\u0430\u0442\u043e\u0440\u0430 \u0434\u043e\u043a\u0443\u043c\u0